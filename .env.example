# ── Application ──────────────────────────────────────────
APP_NAME=WebGenius
APP_ENV=development           # development | production
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-string-in-production
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://webgenius:webgenius@localhost:5432/webgenius
DATABASE_URL_SYNC=postgresql://webgenius:webgenius@localhost:5432/webgenius

# ── Redis (rate limiting & caching) ──────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-too-another-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080      # 7 days

# ── API Key Encryption ────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── Default Rate Limits (overridable per class) ───────────
DEFAULT_IMAGEN_CALLS_PER_STUDENT_PER_DAY=20
DEFAULT_GEMINI_CALLS_PER_STUDENT_PER_DAY=100
DEFAULT_TTS_CALLS_PER_STUDENT_PER_DAY=15
DEFAULT_VEO_CALLS_PER_STUDENT_PER_DAY=5
